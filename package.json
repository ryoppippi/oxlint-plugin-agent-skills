{
	"name": "oxlint-plugin-agent-skills",
	"version": "0.1.0",
	"description": "Oxlint JavaScript plugin for validating Agent Skills against the Agent Skills specification and authoring best practices.",
	"keywords": [
		"agent-skills",
		"claude-code",
		"codex",
		"lint",
		"oxlint",
		"oxlint-plugin"
	],
	"homepage": "https://github.com/ryoppippi/oxlint-plugin-agent-skills#readme",
	"bugs": "https://github.com/ryoppippi/oxlint-plugin-agent-skills/issues",
	"license": "MIT",
	"author": "ryoppippi",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ryoppippi/oxlint-plugin-agent-skills.git"
	},
	"files": [
		"dist",
		"src"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "vp run pack",
		"format": "vp fmt --write",
		"test:watch": "vp test"
	},
	"dependencies": {
		"@oxlint/plugins": "1.70.0",
		"mdast-util-from-markdown": "2.0.3",
		"yaml": "2.9.0"
	},
	"devDependencies": {
		"@types/node": "22.19.21",
		"fs-fixture": "2.14.0",
		"oxlint": "1.72.0",
		"typescript": "7.0.2",
		"vite": "catalog:",
		"vite-plus": "catalog:"
	},
	"peerDependencies": {
		"oxlint": ">=1.70.0"
	},
	"peerDependenciesMeta": {
		"oxlint": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.5.2"
}
