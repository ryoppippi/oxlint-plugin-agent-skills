{
	"name": "oxlint-plugin-agent-skills",
	"version": "0.1.1",
	"description": "Oxlint JavaScript plugin for validating Agent Skills against the Agent Skills specification and authoring best practices.",
	"keywords": [
		"agent-skills",
		"claude-code",
		"codex",
		"lint",
		"oxlint",
		"oxlint-plugin"
	],
	"homepage": "https://github.com/ryoppippi/oxlint-plugin-agent-skills#readme",
	"bugs": "https://github.com/ryoppippi/oxlint-plugin-agent-skills/issues",
	"license": "MIT",
	"author": "ryoppippi",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ryoppippi/oxlint-plugin-agent-skills.git"
	},
	"funding": "https://github.com/sponsors/ryoppippi",
	"files": [
		"dist",
		"src",
		"docs"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "vp run pack",
		"format": "vp fmt --write",
		"prepack": "vp run pack",
		"prepare": "vp config --no-agent",
		"test:watch": "vp test"
	},
	"dependencies": {
		"@oxlint/plugins": "1.70.0",
		"mdast-util-from-markdown": "2.0.3",
		"yaml": "2.9.0"
	},
	"devDependencies": {
		"@types/node": "22.19.21",
		"changelogithub": "14.0.0",
		"fs-fixture": "2.14.0",
		"oxlint": "1.72.0",
		"oxlint-tsgolint": "0.24.0",
		"pkg-pr-new": "0.0.78",
		"publint": "0.3.21",
		"typescript": "7.0.2",
		"unplugin-unused": "0.5.7",
		"vite": "catalog:",
		"vite-plus": "catalog:"
	},
	"peerDependencies": {
		"oxlint": ">=1.70.0"
	},
	"peerDependenciesMeta": {
		"oxlint": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.15.0",
	"changelogithub": {
		"types": {
			"feat": {
				"title": "🚀 Features"
			},
			"fix": {
				"title": "🐞 Bug Fixes"
			},
			"perf": {
				"title": "🏎 Performance"
			},
			"docs": {
				"title": "📖 Documentation"
			}
		}
	}
}
